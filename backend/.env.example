# --- App ---
APP_NAME=Employee Salary Estimator API
APP_VERSION=1.0.0
ENVIRONMENT=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DEBUG=false

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database (NeonDB Postgres) ---
# Runtime (async, psycopg3): postgresql+psycopg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@ep-example-000000.us-east-2.aws.neon.tech/employee_salary?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# --- Redis (Upstash REST API — rate limiting, password reset / email verification tokens) ---
# From the Upstash console: your database's "REST API" section.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=change-me

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-64-byte-hex-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10

# --- ML Service integration ---
ML_SERVICE_BASE_URL=http://localhost:8001
ML_SERVICE_PREDICT_PATH=/api/v1/predict
ML_SERVICE_HEALTH_PATH=/health
ML_SERVICE_API_KEY=change-me-shared-secret
ML_SERVICE_TIMEOUT_SECONDS=10
ML_SERVICE_MAX_RETRIES=2

# --- Password reset / email verification tokens ---
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
